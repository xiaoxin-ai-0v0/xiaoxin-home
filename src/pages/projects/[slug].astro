---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const allProjects = (await getCollection('projects')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const idx = allProjects.findIndex((x) => x.slug === entry.slug);
const prev = idx < allProjects.length - 1 ? allProjects[idx + 1] : null;
const next = idx > 0 ? allProjects[idx - 1] : null;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.date.toISOString(),
  keywords: entry.data.tags.join(',')
};
---

<Layout
  title={`${entry.data.title} | 项目详情`}
  description={entry.data.description}
  type="article"
  structuredData={structuredData}
>
  <article class="neo-card p-8 md:p-10 bg-white">
    <p class="text-xs font-bold text-gray-500">{entry.data.category} · {entry.data.date.toLocaleDateString('zh-CN')}</p>
    <h1 class="text-4xl font-black mt-2">{entry.data.title}</h1>
    <p class="mt-4 text-lg text-gray-700">{entry.data.description}</p>

    <div class="mt-6 flex flex-wrap gap-3">
      {entry.data.demoUrl && <a class="neo-button px-4 py-2 rounded font-bold bg-black text-white" href={entry.data.demoUrl} target="_blank" rel="noopener noreferrer">在线演示</a>}
      {entry.data.repoUrl && <a class="neo-button px-4 py-2 rounded font-bold bg-white text-black" href={entry.data.repoUrl} target="_blank" rel="noopener noreferrer">源码仓库</a>}
      <a class="neo-button px-4 py-2 rounded font-bold bg-white text-black" href="/projects">返回项目列表</a>
    </div>

    <div class="prose prose-lg max-w-none mt-10 prose-headings:font-black prose-headings:border-b-4 prose-headings:border-black prose-a:text-blue-600 prose-code:bg-yellow-100 prose-code:px-2 prose-code:py-1 prose-code:rounded">
      <Content />
    </div>
  </article>

  <section class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-6">
    <div class="neo-card p-5 bg-white">
      <p class="text-sm text-gray-500">上一个项目</p>
      {prev ? <a class="font-black text-xl" href={`/projects/${prev.slug}`}>{prev.data.title}</a> : <p class="font-bold">没有了</p>}
    </div>
    <div class="neo-card p-5 bg-white">
      <p class="text-sm text-gray-500">下一个项目</p>
      {next ? <a class="font-black text-xl" href={`/projects/${next.slug}`}>{next.data.title}</a> : <p class="font-bold">没有了</p>}
    </div>
  </section>
</Layout>
