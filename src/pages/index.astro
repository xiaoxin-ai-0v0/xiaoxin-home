---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const projects = (await getCollection('projects'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const recentPosts = posts.slice(0, 3);
const featuredProjects = projects.filter((p) => p.data.featured).slice(0, 3);

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: '小新',
  url: 'https://xiaoxin-ai-0v0.github.io/xiaoxin-home/',
  sameAs: ['https://github.com/xiaoxin-ai-0v0'],
  jobTitle: '开发者'
};
---

<Layout
  title="小新的个人网站 | 项目与博客"
  description="个人项目、技术博客与创作记录，专注 Web、AI 与小游戏开发。"
  structuredData={structuredData}
>
  <section class="neo-card p-8 md:p-12 bg-white">
    <p class="inline-block bg-purple-300 neo-button px-4 py-1 font-bold rounded-md mb-4">HELLO, I AM XIAOXIN</p>
    <h1 class="text-4xl md:text-6xl font-black leading-tight">
      用项目验证想法，
      <span class="underline decoration-yellow-400">用内容沉淀能力</span>
    </h1>
    <p class="mt-5 text-lg text-gray-700 max-w-3xl">
      这里展示我的项目实践、技术文章和创作记录。网站已升级为多页面结构，方便快速浏览与持续更新。
    </p>
    <div class="flex flex-wrap gap-4 mt-8">
      <a href="/projects" class="neo-button bg-black text-white px-6 py-3 rounded-md font-bold">查看项目</a>
      <a href="/contact" class="neo-button bg-white text-black px-6 py-3 rounded-md font-bold">联系我</a>
      <a href="/blog" class="neo-button bg-white text-black px-6 py-3 rounded-md font-bold">阅读博客</a>
    </div>
  </section>

  <section class="mt-12">
    <div class="flex items-center justify-between mb-5">
      <h2 class="text-3xl font-black">代表项目</h2>
      <a href="/projects" class="font-bold underline">查看全部</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {
        featuredProjects.map((project) => (
          <article class="neo-card p-6 bg-white">
            <p class="text-xs font-bold text-gray-500">{project.data.category}</p>
            <h3 class="text-2xl font-black mt-2">{project.data.title}</h3>
            <p class="mt-3 text-gray-700">{project.data.description}</p>
            <div class="mt-5 flex flex-wrap gap-2">
              {project.data.tags.slice(0, 3).map((tag) => <span class="px-2 py-1 text-xs border-2 border-black rounded-full">#{tag}</span>)}
            </div>
            <a href={`/projects/${project.slug}`} class="inline-block mt-6 neo-button bg-black text-white px-4 py-2 rounded-md font-bold">项目详情</a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="mt-12">
    <div class="flex items-center justify-between mb-5">
      <h2 class="text-3xl font-black">最近更新</h2>
      <a href="/blog" class="font-bold underline">更多文章</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {
        recentPosts.map((post) => (
          <article class="neo-card p-6 bg-white">
            <p class="text-xs font-bold text-gray-500">{post.data.category} · {post.data.date.toLocaleDateString('zh-CN')}</p>
            <h3 class="text-xl font-black mt-2">{post.data.title}</h3>
            <p class="mt-3 text-gray-700">{post.data.description}</p>
            <a href={`/blog/${post.slug}`} class="inline-block mt-6 neo-button bg-black text-white px-4 py-2 rounded-md font-bold">阅读全文</a>
          </article>
        ))
      }
    </div>
  </section>
</Layout>
