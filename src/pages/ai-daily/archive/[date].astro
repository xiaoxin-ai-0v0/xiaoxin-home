---
import Layout from '../../../layouts/Layout.astro';
import { loadArchiveByDate, loadArchiveIndex } from '../../../lib/ai-daily/load.mjs';

export async function getStaticPaths() {
  const entries = await loadArchiveIndex();
  return entries.map((entry: any) => ({
    params: { date: entry.date },
    props: { entry },
  }));
}

const { date } = Astro.params;
const archive = await loadArchiveByDate(date!);
---

<Layout
  title={`${archive.date} AI 归档 | 小新的个人网站`}
  description={archive.summary?.overview || `${archive.date} 的 AI 资讯归档`}
>
  <section class="neo-card surface-tint p-8 md:p-12">
    <p class="section-kicker mb-4">daily archive</p>
    <h1 class="headline-display font-black">{archive.summary?.headline || `${archive.date} AI 归档`}</h1>
    <p class="mt-4 text-lg text-gray-700">{archive.summary?.overview}</p>
    <p class="mt-4 text-sm font-bold text-gray-500">归档日期 | {archive.date}</p>
  </section>

  <section class="neo-card p-7 bg-white/90 mt-8">
    <h2 class="text-2xl font-black">当日重点</h2>
    <ul class="mt-4 space-y-3">
      {(archive.summary?.highlights || []).map((point: string) => <li class="font-bold text-gray-800">- {point}</li>)}
    </ul>
  </section>

  <section class="mt-12">
    <div class="flex items-center justify-between mb-5">
      <h2 class="text-3xl font-black">资讯条目</h2>
      <span class="chip">{archive.counts?.items || archive.items.length} 条</span>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {archive.items.map((item: any) => (
        <article class="neo-card p-6 bg-white/90">
          <div class="flex flex-wrap gap-2">
            {(item.tags || []).map((tag: string) => <span class="chip">#{tag}</span>)}
          </div>
          <h3 class="text-2xl font-black mt-4 text-balance">{item.titleZh || item.title}</h3>
          <p class="mt-2 text-sm font-bold text-gray-500">{item.source}</p>
          <p class="mt-3 text-gray-700">{item.snippetZh || item.snippet}</p>
          <details class="mt-4">
            <summary class="font-bold cursor-pointer">查看原文片段</summary>
            <p class="mt-2 text-sm text-gray-600">{item.content}</p>
          </details>
          <a
            href={item.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block mt-6 neo-button bg-black text-white px-4 py-2 rounded-md font-bold"
          >
            打开来源
          </a>
        </article>
      ))}
    </div>
  </section>
</Layout>
