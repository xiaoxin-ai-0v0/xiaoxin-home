---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  structuredData?: Record<string, unknown>;
}

const {
  title,
  description = '小新的个人网站：项目、博客与创作记录。',
  image = '/images/ai-wind.png',
  type = 'website',
  structuredData
} = Astro.props;

const site = Astro.site ?? new URL('https://xiaoxin-ai-0v0.github.io/xiaoxin-home/');
const canonical = new URL(Astro.url.pathname, site).toString();
const ogImage = image.startsWith('http') ? image : new URL(image, site).toString();
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path: string) => {
  if (path.startsWith('http')) return path;
  if (path === '/') return `${basePath}/` || '/';
  return `${basePath}${path}`;
};
const navLinks = [
  { href: '/', label: '首页' },
  { href: '/ai-daily', label: 'AI观察' },
  { href: '/about', label: '关于' },
  { href: '/projects', label: '项目' },
  { href: '/blog', label: '博客' },
  { href: '/contact', label: '联系' },
];
const activePath = Astro.url.pathname.startsWith(basePath)
  ? Astro.url.pathname.slice(basePath.length) || '/'
  : Astro.url.pathname;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />

    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Noto+Sans+SC:wght@400;500;700;900&display=swap" rel="stylesheet" />

    {
      structuredData && (
        <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
      )
    }
  </head>
  <body class="min-h-screen flex flex-col">
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
      <div class="absolute -top-16 -left-16 h-64 w-64 rounded-full bg-[#ffc85e]/45 blur-3xl"></div>
      <div class="absolute top-24 -right-20 h-72 w-72 rounded-full bg-[#68d2ff]/35 blur-3xl"></div>
      <div class="absolute bottom-0 left-1/3 h-80 w-80 rounded-full bg-[#ff8f68]/20 blur-3xl"></div>
    </div>

    <nav class="sticky top-4 z-50 mx-auto max-w-5xl px-4 w-full">
      <div class="neo-card rounded-[999px] px-4 md:px-6 py-3 flex justify-between items-center bg-white/90 backdrop-blur-md">
        <a href={withBase('/')} class="text-xl md:text-2xl font-black tracking-tight hover:text-[#f97316] transition-colors">XIAOXIN.STUDIO</a>
        <div class="flex gap-1 md:gap-2 font-bold text-xs md:text-sm">
          {
            navLinks.map((item) => (
              <a
                href={withBase(item.href)}
                class:list={[
                  'nav-link px-2 md:px-3 py-1 rounded-full transition-colors hover:bg-yellow-200/80',
                  { 'bg-yellow-400': activePath === item.href || (item.href !== '/' && activePath.startsWith(item.href)) }
                ]}
              >
                {item.label}
              </a>
            ))
          }
        </div>
      </div>
    </nav>

    <main class="page-shell flex-1 max-w-6xl mx-auto px-4 py-12 w-full">
      <slot />
    </main>

    <footer class="border-t-2 border-black/80 bg-white/80 backdrop-blur-md p-10 shrink-0">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
        <div class="font-black text-2xl italic">Build. Learn. Ship.</div>
        <div class="flex gap-6 font-bold">
          <a href="https://github.com/xiaoxin-ai-0v0" target="_blank" rel="noopener noreferrer" class="hover:text-blue-500 transition-colors">GitHub</a>
          <a href="https://v.douyin.com/b_pHGZTQXWk/" target="_blank" rel="noopener noreferrer" class="hover:text-pink-500 transition-colors">抖音</a>
          <a href={withBase('/rss.xml')} class="hover:text-orange-500 transition-colors">RSS</a>
        </div>
        <p class="text-sm text-gray-500 font-bold">© 2026 xiaoxin-ai-0v0</p>
      </div>
    </footer>
  </body>
</html>
